<html>
  <body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f4f4f4; color:#333;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding: 20px 0;">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 0 10px rgba(0,0,0,0.1);">

            <!-- Header -->
            <tr>
              <td style="background-color:#000000; color:#ffffff; text-align:center; padding:30px; font-size:26px; font-weight:bold;">
                💰 Payment Refunded
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:30px;">
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  Hello Admin,
                </p>
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  A payment refund has been processed:
                </p>

                <!-- Payment Information -->
                <div style="background-color:#f9f9f9; border-left:4px solid #28a745; padding:15px; margin:20px 0;">
                  <p style="margin:0 0 10px 0; font-size:18px; font-weight:bold; color:#28a745;">
                    Order #{{order_display_id}}
                  </p>
                  {{#if customer_name}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Customer:</strong> {{customer_name}}
                  </p>
                  {{/if}}
                  {{#if customer_email}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Email:</strong> {{customer_email}}
                  </p>
                  {{/if}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Payment ID:</strong> {{payment_id}}
                  </p>
                  {{#if refund_id}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Refund ID:</strong> {{refund_id}}
                  </p>
                  {{/if}}
                </div>

                <!-- Refund Details -->
                <table width="100%" cellpadding="8" cellspacing="0" border="0" style="border:1px solid #eee; margin:20px 0; border-collapse:collapse; font-size:15px;">
                  <tr style="background-color:#d4edda;">
                    <td style="border:1px solid #eee; padding:12px; font-weight:bold;">Refund Amount:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#155724; font-weight:bold; font-size:18px;">&#8377; {{refund_amount}}</td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Original Amount:</td>
                    <td style="border:1px solid #eee; padding:12px;"> &#8377; {{original_amount}}</td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Total Refunded:</td>
                    <td style="border:1px solid #eee; padding:12px;"> &#8377; {{total_refunded}}</td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Refund Type:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#28a745; font-weight:bold;">
                      {{#if is_partial_refund}}
                        Partial Refund
                      {{else}}
                        Full Refund
                      {{/if}}
                    </td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Status:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#28a745; font-weight:bold;">{{payment_status}}</td>
                  </tr>
                </table>

                <!-- Action Buttons -->
                {{!-- <div style="text-align:center; margin:25px 0;">
                  {{#if order_link}}
                  <a href="{{order_link}}" style="display:inline-block; background-color:#28a745; color:#ffffff; padding:12px 30px; text-decoration:none; border-radius:5px; font-weight:bold; font-size:16px; margin:5px;">
                    View Order
                  </a>
                  {{/if}}
                  {{#if payment_link}}
                  <a href="{{payment_link}}" style="display:inline-block; background-color:#6c757d; color:#ffffff; padding:12px 30px; text-decoration:none; border-radius:5px; font-weight:bold; font-size:16px; margin:5px;">
                    View Payment
                  </a>
                  {{/if}}
                </div> --}}

                <!-- Divider -->
                <hr style="border:none; border-top:1px solid #eee; margin:20px 0;" />

                <p style="margin-top:20px; font-size:14px; line-height:1.6; color:#666;">
                  The refund has been successfully processed. The customer should receive the refund according to your payment provider's processing time.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#f4f4f4; color:#999; text-align:center; padding:15px; font-size:12px;">
                &copy; 2025 {{store_name}}. All rights reserved.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>

