<html>
  <body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f4f4f4; color:#333;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding: 20px 0;">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 0 10px rgba(0,0,0,0.1);">

            <!-- Header -->
            <tr>
              <td style="background-color:#000000; color:#ffffff; text-align:center; padding:30px; font-size:26px; font-weight:bold;">
                ✅ Payment Captured
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:30px;">
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  {{#if customer_name}}
                  Hello {{customer_name}},
                  {{else}}
                  Hello,
                  {{/if}}
                </p>
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  {{message}}
                </p>

                <!-- Payment Information -->
                <div style="background-color:#d4edda; border-left:4px solid #28a745; padding:15px; margin:20px 0; border-radius:4px;">
                  <p style="margin:0 0 10px 0; font-size:18px; font-weight:bold; color:#155724;">
                    {{heading}}
                  </p>
                  {{#if order_display_id}}
                  <p style="margin:0; font-size:14px; color:#155724;">
                    Order: #{{order_display_id}}
                  </p>
                  {{/if}}
                </div>

                <!-- Payment Details -->
                <table width="100%" cellpadding="8" cellspacing="0" border="0" style="border:1px solid #eee; margin:20px 0; border-collapse:collapse; font-size:15px;">
                  <tr style="background-color:#d4edda;">
                    <td style="border:1px solid #eee; padding:12px; font-weight:bold;">Amount:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#155724; font-weight:bold; font-size:18px;">{{currency_code}} {{amount}}</td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Status:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#28a745; font-weight:bold;">{{payment_status}}</td>
                  </tr>
                  {{#if order_display_id}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Order ID:</td>
                    <td style="border:1px solid #eee; padding:12px;">#{{order_display_id}}</td>
                  </tr>
                  {{/if}}
                  {{#if captured_at}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Captured At:</td>
                    <td style="border:1px solid #eee; padding:12px;">{{captured_at}}</td>
                  </tr>
                  {{/if}}
                </table>

                <!-- Action Buttons -->
                {{#if order_link}}
                <div style="text-align:center; margin:30px 0;">
                  <a href="{{order_link}}" style="display:inline-block; background-color:#28a745; color:#ffffff; padding:12px 30px; text-decoration:none; border-radius:5px; font-weight:bold; font-size:16px;">
                    View Order Details
                  </a>
                </div>
                {{/if}}

                <!-- Footer -->
                <tr>
                  <td style="padding:20px 30px; background-color:#f8f9fa; text-align:center; font-size:12px; color:#6c757d; border-top:1px solid #eee;">
                    <p style="margin:0 0 5px 0;">
                      This is an automated notification from {{store_name}}.
                    </p>
                    <p style="margin:0;">
                      If you have any questions, please contact our support team.
                    </p>
                  </td>
                </tr>

              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>

