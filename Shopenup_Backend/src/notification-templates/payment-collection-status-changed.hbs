<html>
  <body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f4f4f4; color:#333;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding: 20px 0;">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 0 10px rgba(0,0,0,0.1);">

            <!-- Header -->
            <tr>
              <td style="background-color:#000000; color:#ffffff; text-align:center; padding:30px; font-size:26px; font-weight:bold;">
                🔄 Payment Status Update
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:30px;">
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  Hello Admin,
                </p>
                <p style="margin:0 0 15px 0; font-size:16px; line-height:1.6;">
                  A payment collection status has changed:
                </p>

                <!-- Payment Information -->
                <div style="background-color:#f9f9f9; border-left:4px solid #ffc107; padding:15px; margin:20px 0;">
                  <p style="margin:0 0 10px 0; font-size:18px; font-weight:bold; color:#856404;">
                    Order #{{order_display_id}}
                  </p>
                  {{#if customer_name}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Customer:</strong> {{customer_name}}
                  </p>
                  {{/if}}
                  {{#if customer_email}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Email:</strong> {{customer_email}}
                  </p>
                  {{/if}}
                  <p style="margin:0 0 5px 0; font-size:14px; color:#666;">
                    <strong>Payment Collection ID:</strong> {{payment_collection_id}}
                  </p>
                </div>

                <!-- Status Details -->
                <table width="100%" cellpadding="8" cellspacing="0" border="0" style="border:1px solid #eee; margin:20px 0; border-collapse:collapse; font-size:15px;">
                  <tr style="background-color:#fff3cd;">
                    <td style="border:1px solid #eee; padding:12px; font-weight:bold;">Amount:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#856404; font-weight:bold; font-size:18px;">{{currency_code}} {{amount}}</td>
                  </tr>
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Current Status:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#856404; font-weight:bold; text-transform:uppercase;">{{status}}</td>
                  </tr>
                  {{#if previous_status}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Previous Status:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#666; text-transform:uppercase;">{{previous_status}}</td>
                  </tr>
                  {{/if}}
                  {{#if authorized_amount}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Authorized Amount:</td>
                    <td style="border:1px solid #eee; padding:12px;">{{currency_code}} {{authorized_amount}}</td>
                  </tr>
                  {{/if}}
                  {{#if refunded_amount}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Refunded Amount:</td>
                    <td style="border:1px solid #eee; padding:12px;">{{currency_code}} {{refunded_amount}}</td>
                  </tr>
                  {{/if}}
                  <tr>
                    <td style="border:1px solid #eee; padding:12px;">Alert Level:</td>
                    <td style="border:1px solid #eee; padding:12px; color:#856404; font-weight:bold;">{{alert_level}}</td>
                  </tr>
                </table>

                <!-- Action Buttons -->
                <div style="text-align:center; margin:25px 0;">
                  {{#if order_link}}
                  <a href="{{order_link}}" style="display:inline-block; background-color:#ffc107; color:#333; padding:12px 30px; text-decoration:none; border-radius:5px; font-weight:bold; font-size:16px; margin:5px;">
                    View Order
                  </a>
                  {{/if}}
                  {{#if payment_collection_link}}
                  <a href="{{payment_collection_link}}" style="display:inline-block; background-color:#6c757d; color:#ffffff; padding:12px 30px; text-decoration:none; border-radius:5px; font-weight:bold; font-size:16px; margin:5px;">
                    View Payment Collection
                  </a>
                  {{/if}}
                </div>

                <!-- Divider -->
                <hr style="border:none; border-top:1px solid #eee; margin:20px 0;" />

                <p style="margin-top:20px; font-size:14px; line-height:1.6; color:#666;">
                  Please review the payment collection status and take any necessary action if required.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#f4f4f4; color:#999; text-align:center; padding:15px; font-size:12px;">
                &copy; 2025 {{store_name}}. All rights reserved.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>

