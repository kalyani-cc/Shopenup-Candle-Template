<html>
  <body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f4f4f4; color:#333;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding: 20px 0;">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 0 10px rgba(0,0,0,0.1);">
            
            <!-- Header -->
            <tr>
              <td style="background-color:#000000; color:#ffffff; text-align:center; padding:30px; font-size:26px; font-weight:bold;">
                📋 Daily Appointment Summary
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:30px;">
                <h2 style="margin:0 0 15px 0; color:#000000;">Daily Appointment Report</h2>
                <p style="margin:0 0 20px 0; font-size:16px; line-height:1.6;">
                  Here is a summary of all appointments scheduled for <strong>{{date}}</strong>.
                </p>

                <!-- Summary Box -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f9f9f9; border:1px solid #eee; border-radius:6px; margin:20px 0;">
                  <tr>
                    <td style="padding:20px;">
                      <h3 style="margin:0 0 15px 0; color:#000000; font-size:18px;">Summary</h3>
                      <p style="margin:0; font-size:16px;">
                        <strong>Total Appointments:</strong> {{totalAppointments}}
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Appointments List -->
                {{#if appointments}}
                <div style="margin:20px 0;">
                  <h3 style="margin:0 0 15px 0; color:#000000; font-size:18px;">Appointment Details</h3>
                  
                  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; border:1px solid #ddd;">
                    <!-- Table Header -->
                    <thead>
                      <tr style="background-color:#000000; color:#ffffff;">
                        <th style="padding:12px; text-align:left; font-size:14px; font-weight:bold; border:1px solid #ddd;">Patient Name</th>
                        <th style="padding:12px; text-align:left; font-size:14px; font-weight:bold; border:1px solid #ddd;">Time</th>
                        <th style="padding:12px; text-align:left; font-size:14px; font-weight:bold; border:1px solid #ddd;">Email</th>
                        <th style="padding:12px; text-align:left; font-size:14px; font-weight:bold; border:1px solid #ddd;">Mobile</th>
                        <th style="padding:12px; text-align:left; font-size:14px; font-weight:bold; border:1px solid #ddd;">Status</th>
                      </tr>
                    </thead>
                    <!-- Table Body -->
                    <tbody>
                      {{#each appointments}}
                      <tr style="background-color:#ffffff;">
                        <td style="padding:12px; font-size:14px; border:1px solid #ddd;">{{fullName}}</td>
                        <td style="padding:12px; font-size:14px; border:1px solid #ddd; white-space:nowrap;">
                          <div style="font-weight:500; color:#333;">{{startTime}}</div>
                          <div style="font-size:12px; color:#666; margin-top:2px;">to {{endTime}}</div>
                        </td>
                        <td style="padding:12px; font-size:14px; border:1px solid #ddd;">{{email}}</td>
                        <td style="padding:12px; font-size:14px; border:1px solid #ddd;">{{mobileNumber}}</td>
                        <td style="padding:12px; font-size:14px; border:1px solid #ddd;">
                          <span style="padding:4px 8px; border-radius:4px; font-size:12px; background:#e9ecef; color:#495057;">
                            {{status}}
                          </span>
                        </td>
                      </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
                {{else}}
                <div style="background:#d1ecf1; border-left:4px solid #0c5460; padding:15px; margin:20px 0; border-radius:4px;">
                  <p style="margin:0; font-size:14px; line-height:1.6;">
                    No appointments scheduled for today.
                  </p>
                </div>
                {{/if}}

                <p style="margin-top:20px; font-size:16px; line-height:1.6;">
                  Best regards,<br />
                  <strong>{{store_name}} Appointment System</strong>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#f4f4f4; color:#999; text-align:center; padding:15px; font-size:12px;">
                &copy; 2025 {{store_name}}. All rights reserved. <br />
                This is an automated daily summary email from the appointment booking system.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>

