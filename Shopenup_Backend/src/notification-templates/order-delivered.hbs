<body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f4f4f4; color:#333;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" style="padding: 20px 0;">
        <table width="600" cellpadding="0" cellspacing="0" border="0"
          style="background-color:#ffffff; border-radius:10px; overflow:hidden; box-shadow:0 4px 15px rgba(0,0,0,0.1);">

          <!-- Header -->
          <tr>
            <td style="background-color:#000000; color:#ffffff; text-align:center; padding:30px 20px; font-size:26px; font-weight:bold;">
              🎉 Your Order Has Been Delivered!
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:25px 30px;">
              <p style="font-size:18px; margin:0 0 10px 0;">Hi {{first_name}},</p>
              <p style="margin:0 0 20px 0;">Great news! Your order has been successfully <strong>delivered</strong>.</p>

              <p style="margin:0 0 20px 0;">Order ID: <strong>{{order_id}}</strong></p>

              <!-- Shipping & Billing -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                <tr>
                  <td style="vertical-align:top; padding-right:15px;">
                    <h4 style="margin:0 0 5px 0; font-size:16px;">Shipping Address</h4>
                    <p style="margin:0; font-size:14px;">{{address_1}} {{address_2}}</p>
                    <p style="margin:0; font-size:14px;">Phone: {{phone}}</p>
                  </td>
                  <td style="vertical-align:top; padding-left:15px;">
                    <h4 style="margin:0 0 5px 0; font-size:16px;">Billing Address</h4>
                    <p style="margin:0; font-size:14px;">{{billing_address_1}} {{billing_address_2}}</p>
                    <p style="margin:0; font-size:14px;">Phone: {{billing_phone}}</p>
                  </td>
                </tr>
              </table>

              <!-- Order Items -->
              <h3 style="margin-bottom:10px; font-size:20px;">Your Items</h3>
              <table width="100%" cellpadding="8" cellspacing="0" border="0"
                style="border:1px solid #eee; margin-bottom:25px; border-collapse:collapse; font-size:15px;">
                <thead>
                  <tr style="background-color:#f9f9f9;">
                    <th style="border:1px solid #eee; padding:8px; text-align:left;">Product</th>
                    <th style="border:1px solid #eee; padding:8px; text-align:center;">Qty</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each items}}
                  <tr>
                    <td style="border:1px solid #eee; padding:8px;">{{name}}</td>
                    <td style="border:1px solid #eee; padding:8px; text-align:center;">{{quantity}}</td>
                  </tr>
                  {{/each}}
                </tbody>
              </table>

              <!-- Review & Return Buttons -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:20px 0;">
                <tr>
                  <td align="center" style="padding-bottom:12px;">
                    <a href="{{order_link}}"
                       style="display:inline-block; padding:12px 26px; background-color:#000000;
                              color:#ffffff; text-decoration:none; border-radius:6px;
                              font-size:14px; font-weight:bold;">
                      ⭐ Add a Review
                    </a>
                  </td>
                </tr>
                <tr>
                  <td align="center">
                    <a href="{{order_link}}"
                       style="display:inline-block; padding:10px 24px; background-color:#ffffff;
                              color:#000000; text-decoration:none; border:1px solid #000000;
                              border-radius:6px; font-size:14px; font-weight:bold;">
                      🔄 Return / Replace Product
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin-top:20px; font-size:15px;">
                Thank you for shopping with us! We hope you enjoy your products.
              </p>

              <p style="margin-top:15px; font-size:12px; color:#999;">
                If you have any questions, reply to this email or contact our support team.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f4f4f4; color:#999; text-align:center; padding:15px; font-size:12px;">
              &copy; 2025 Shopenup. All rights reserved.
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
